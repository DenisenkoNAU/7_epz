<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Width="360"
             Height="480"
             x:Class="lw_2.MainPage"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}"
             Shell.NavBarIsVisible="False">

        <VerticalStackLayout
            Padding="24"
            Spacing="24">

            <Frame 
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                BorderColor="{AppThemeBinding Light=#E2E8F0, Dark=#2D3748}"
                CornerRadius="10" 
                Padding="16" >
                
                <VerticalStackLayout Spacing="16">
                    
                    <Label 
                        Text="Розрахунок базової моделі COCOMO" 
                        FontSize="22" 
                        FontAttributes="Bold" 
                        TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

                    <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,8" />

                    <VerticalStackLayout Spacing="8">
                        <Label 
                            Text="Кількіть рядків коду (тисяч)" 
                            FontSize="12" 
                            FontAttributes="Bold" 
                            TextColor="#334155" 
                            TextTransform="Uppercase"
                            CharacterSpacing="0.5" />
                        <Entry 
                            x:Name="TxtCodeSize"
                            Placeholder="320"
                            Keyboard="Numeric"
                            FontSize="16"
                            HeightRequest="48"
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                            BackgroundColor="Transparent" />

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label 
                            Text="Тип проекту" 
                            FontSize="12" 
                            FontAttributes="Bold" 
                            TextColor="#334155" 
                            TextTransform="Uppercase"
                            CharacterSpacing="0.5" />
                        <Picker 
                            x:Name="CmbProjectType"
                            FontSize="16"
                            HeightRequest="48"
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </VerticalStackLayout>

                    <Button
                        x:Name="BtnCalculate"
                        Text="Розрахувати"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="8"
                        BackgroundColor="#319795"
                        TextColor="White"
                        Margin="0,8,0,0"
                        Clicked="OnCalculateClicked"/>
                    
                </VerticalStackLayout>
            </Frame>

            <Frame 
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                BorderColor="{AppThemeBinding Light=#E2E8F0, Dark=#2D3748}"
                CornerRadius="10" 
                Padding="16" 
                HasShadow="False">
                
                <VerticalStackLayout Spacing="16">
                    <Label
                        Text="Результати розрахунку"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextTransform="Uppercase"
                        TextColor="#319795"
                        CharacterSpacing="0.5"
                        Margin="0,0,0,8"/>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label 
                            Grid.Column="0" 
                            Text="Трудомісткість (PM)" 
                            TextColor="#64748B" 
                            FontSize="16" 
                            VerticalOptions="Center"/>
                        <Label 
                            Grid.Column="1" 
                            x:Name="LblEfforts" 
                            Text="—" 
                            FontAttributes="Bold" 
                            FontSize="16" 
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F1F5F9" />
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label 
                            Grid.Column="0" 
                            Text="Час розробки (TM)" 
                            TextColor="#64748B" 
                            FontSize="16" 
                            VerticalOptions="Center"/>
                        <Label 
                            Grid.Column="1" 
                            x:Name="LblTimeTo" 
                            Text="—" 
                            FontAttributes="Bold" 
                            FontSize="16" 
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F1F5F9" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label 
                            Grid.Column="0" 
                            Text="Чисельність розробників (SS)" 
                            TextColor="#64748B" 
                            FontSize="16" 
                            VerticalOptions="Center"/>
                        <Label 
                            Grid.Column="1" 
                            x:Name="LblDevelopers" 
                            Text="—" 
                            FontAttributes="Bold" 
                            FontSize="16" 
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F1F5F9" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label 
                            Grid.Column="0" 
                            Text="Продуктивність (P)" 
                            TextColor="#64748B" 
                            FontSize="16" 
                            VerticalOptions="Center"/>
                        <Label 
                            Grid.Column="1" 
                            x:Name="LblProductivity" 
                            Text="—" 
                            FontAttributes="Bold" 
                            FontSize="16" 
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                    </Grid>
                    
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
</ContentPage>
